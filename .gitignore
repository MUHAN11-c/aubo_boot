# ROS/ROS2 构建和开发目录
# 忽略所有工作空间中的 build 目录
build/
**/build/
aubo_ros2_ws/build/
aubo_ws/build/
ros2_ws/build/

# 忽略所有工作空间中的 install 目录
install/
**/install/
aubo_ros2_ws/install/
ros2_ws/install/

# 忽略所有工作空间中的 log 目录
log/
**/log/
aubo_ros2_ws/log/
ros2_ws/log/

# 忽略所有工作空间中的 devel 目录
devel/
**/devel/
aubo_ws/devel/

# VS Code 数据库和缓存（避免超大 browse.vc.db 被提交）
**/.vscode/browse.vc.db
**/.vscode/*.db
**/.vscode/*.db-*

# 大体积 zip 包（超过 GitHub 推荐 50MB，请用 LFS 或文档说明另行获取）
*.zip
aubo_ros2_ws/src/aubo_ros2_driver.zip


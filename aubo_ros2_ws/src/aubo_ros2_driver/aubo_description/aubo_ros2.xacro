<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="aubo_robot">
  <xacro:arg name="transmission_hw_interface" default=""/>
  <xacro:arg name="robot_ip" default="None"/>
    <xacro:property name="robot_ip" value="$(arg robot_ip)"/>
  <xacro:arg name="aubo_type" default="None"/>
    <xacro:property name="aubo_type" value="$(arg aubo_type)"/>
  <xacro:arg name="use_fake_hardware" default="true"/>
    <xacro:property name="use_fake_hardware" value="$(arg use_fake_hardware)"/>
  
  <!-- AUBO E5_10 arm links & joints (inlined from aubo_e5_10_clean.urdf) -->
  <link name="base_link">
    <inertial>
      <origin xyz="-1.4795E-13 0.0015384 0.020951" rpy="0 0 0" />
      <mass value="0.83419" />
      <inertia ixx="0.0014414" ixy="7.8809E-15" ixz="8.5328E-16" iyy="0.0013542" iyz="-1.4364E-05" izz="0.0024659" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://aubo_description/meshes/aubo_e5_10/visual/link0.DAE" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://aubo_description/meshes/aubo_e5_10/collision/link0.STL" />
      </geometry>
    </collision>
  </link>

  <link name="shoulder_Link">
    <inertial>
      <origin xyz="0 0.0038 0.0006" rpy="0 0 0" />
      <mass value="5.05" />
      <inertia ixx="0.0148" ixy="0" ixz="0" iyy="0.0143" iyz="0" izz="0.0095" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://aubo_description/meshes/aubo_e5_10/visual/link1.DAE" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://aubo_description/meshes/aubo_e5_10/collision/link1.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <origin xyz="0 0 0.122" rpy="0 0 3.1415926535897932384626433832795" />
    <parent link="base_link" />
    <child link="shoulder_Link" />
    <axis xyz="0 0 1" />
    <limit lower="-3.054326190990076759616458844855" upper="3.054326190990076759616458844855" effort="133" start_stop="207" velocity="2.5964" />
  </joint>

  <link name="upperArm_Link">
    <inertial>
      <origin xyz="0.2040 0 0.0196" rpy="0 0 0" />
      <mass value="11.28" />
      <inertia ixx="0.0305" ixy="0" ixz="0" iyy="0.4505" iyz="0" izz="0.4400" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://aubo_description/meshes/aubo_e5_10/visual/link2.DAE" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://aubo_description/meshes/aubo_e5_10/collision/link2.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="upperArm_joint" type="revolute">
    <origin xyz="0 0.1215 0" rpy="-1.5707963267948966192313216916398 -1.5707963267948966192313216916398 0" />
    <parent link="shoulder_Link" />
    <child link="upperArm_Link" />
    <axis xyz="0 0 1" />
    <limit lower="-3.054326190990076759616458844855" upper="3.054326190990076759616458844855" effort="133" start_stop="207" velocity="2.5964" />
  </joint>

  <link name="foreArm_Link">
    <inertial>
      <origin xyz="0.2699 0 0.0992" rpy="0 0 0" />
      <mass  value="2.88" />
      <inertia ixx="0.0033" ixy="0" ixz="0" iyy="0.0575" iyz="0" izz="0.0565" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://aubo_description/meshes/aubo_e5_10/visual/link3.DAE" />

<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- /////////////////////////////////   Camera Link   ////////////////////////////////////// -->
  <link name="camera_Link">
    <inertial>
      <origin
        xyz="-0.0005963 0.085972 -0.026401"
        rpy="0 0 0" />
      <mass
        value="0.72743" />
      <inertia
        ixx="0.00064649"
        ixy="2.7688E-06"
        ixz="-2.0272E-05"
        iyy="0.0013072"
        iyz="8.2399E-05"
        izz="0.0014971" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://aubo_description/meshes/end_effector/camera_Link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://aubo_description/meshes/end_effector/camera_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="camera_joint"
    type="fixed">
    <origin
      xyz="0.0 0.0 0.020"
      rpy="0.0 0.0 0.0" />
    <parent
      link="wrist3_Link" />
    <child
      link="camera_Link" />
  </joint>


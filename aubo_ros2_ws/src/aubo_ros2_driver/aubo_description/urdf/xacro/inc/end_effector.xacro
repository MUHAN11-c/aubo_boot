  <joint name="grap1_to_tip_joint" type="fixed">
    <parent link="wrist3_Link" />
    <child link="gripper_tip_link" />
    <origin xyz="0.0 0.0 0.185" rpy="0.0 0.0 0.0" />
  </joint>


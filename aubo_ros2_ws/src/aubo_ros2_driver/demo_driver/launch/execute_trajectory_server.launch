<?xml version="1.0"?>
<launch>
  <!-- Execute Trajectory Service Server Node -->
  <node name="execute_trajectory_server_node" 
        pkg="demo_driver" 
        type="execute_trajectory_server_node" 
        output="screen">
    
    <!-- Parameters -->
    <param name="planning_group_name" value="manipulator_e5" />
    <param name="base_frame" value="base_link" />
  </node>
</launch>


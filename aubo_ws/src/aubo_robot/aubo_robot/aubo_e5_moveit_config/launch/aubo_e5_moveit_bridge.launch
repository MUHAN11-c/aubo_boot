<?xml version="1.0"?>
<launch>
  <!-- 加载机器人描述和 MoveIt 规划上下文 -->
  <include file="$(find aubo_e5_moveit_config)/launch/planning_context.launch">
    <arg name="load_robot_description" value="true"/>
  </include>

  <!-- 轨迹插值已迁移到 ROS2（aubo_robot_simulator_ros2），ROS1 仅保留 aubo_driver 接收 moveItController_cmd -->
  <!-- 原 aubo_controller 参数与 aubo_robot_simulator / aubo_joint_trajectory_action 已在 ROS2 侧配置 -->
  <node name="aubo_driver" pkg="aubo_driver" type="aubo_driver" cwd="node">
    <param name="/server_host" type="str" value="169.254.10.98"/>
  </node>
  
  <!-- 机器人反馈节点 -->
  <node name="robot_status_publisher_node" 
        pkg="demo_driver" 
        type="robot_status_publisher_node" 
        output="screen">
  </node>
  <node name="robot_io_status_publisher_node" 
        pkg="demo_driver" 
        type="robot_io_status_publisher_node" 
        output="screen">
  </node>
    <node name="set_robot_io_server_node" 
        pkg="demo_driver" 
        type="set_robot_io_server_node" 
        output="screen">
  </node>
    <node name="read_robot_io_server_node" 
        pkg="demo_driver" 
        type="read_robot_io_server_node" 
        output="screen">
  </node>
    <node name="set_robot_enable_server_node" 
        pkg="demo_driver" 
        type="set_robot_enable_server_node" 
        output="screen">
  </node>
</launch>
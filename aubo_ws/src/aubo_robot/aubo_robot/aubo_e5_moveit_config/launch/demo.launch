<launch>

  <!-- 规划管道：指定运动规划器，默认 lerp -->
  <arg name="pipeline" default="lerp" />

  <!-- 是否启动场景数据库：默认不启动（数据库可能较大） -->
  <arg name="db" default="false" />
  <!-- 场景数据库存储路径 -->
  <arg name="db_path" default="$(find aubo_e5_moveit_config)/default_warehouse_mongo_db" />

  <!-- 是否以调试模式运行：默认关闭 -->
  <arg name="debug" default="false" />

  <!--
  是否显示关节状态发布器的 GUI：默认隐藏
  demo 模式用 joint_state_publisher 替代真实机器人驱动，
  用于维护并发布仿真机器人的关节配置，也可通过 GUI 手动拖动关节，
  相当于不用 MoveIt 手动移动真实机器人。
  -->
  <arg name="use_gui" default="false" />

  <!-- 在参数服务器上加载 URDF、SRDF 及其他 yaml 配置 -->
  <include file="$(find aubo_e5_moveit_config)/launch/planning_context.launch">
    <arg name="load_robot_description" value="true"/>
  </include>

  <!-- 如需为机器人根坐标系发布静态 tf，可在此添加 -->


  <!-- 无真实机器人连接时，发布仿真关节状态（来自 move_group 的 fake_controller） -->
  <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher">
    <param name="use_gui" value="$(arg use_gui)"/>
    <rosparam param="source_list">[move_group/fake_controller_joint_states]</rosparam>
  </node>

  <!-- 根据已发布的关节状态，发布机器人各连杆的 tf -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="true" output="screen" />

  <!-- 启动 MoveIt move_group：允许轨迹执行、使用仿真执行，无真实控制器 -->
  <include file="$(find aubo_e5_moveit_config)/launch/move_group.launch">
    <arg name="allow_trajectory_execution" value="true"/>
    <arg name="fake_execution" value="true"/>
    <arg name="info" value="true"/>
    <arg name="debug" value="$(arg debug)"/>
    <arg name="pipeline" value="$(arg pipeline)"/>
  </include>

  <!-- 启动 RViz 并加载默认配置，用于查看 move_group 的规划与状态 -->
  <include file="$(find aubo_e5_moveit_config)/launch/moveit_rviz.launch">
    <arg name="config" value="true"/>
    <arg name="debug" value="$(arg debug)"/>
  </include>

  <!-- 若启用了数据库加载，则同时启动 MongoDB 场景库 -->
  <include file="$(find aubo_e5_moveit_config)/launch/default_warehouse_db.launch" if="$(arg db)">
    <arg name="moveit_warehouse_database_path" value="$(arg db_path)"/>
  </include>

</launch>

<launch>
  <!-- 是否加载机器人 URDF：默认不覆盖已有 URDF，设为 true 可改变默认行为 -->
  <arg name="load_robot_description" default="false"/>

  <!-- 加载 URDF 时使用的参数名 -->
  <arg name="robot_description" default="robot_description"/>

  <!-- 加载通用机器人描述格式 (URDF)，通过 xacro 解析 aubo_e5.xacro -->
  <param if="$(arg load_robot_description)" name="$(arg robot_description)" command="xacro --inorder  '$(find aubo_gazebo)/urdf/aubo_e5.xacro'"/>

  <!-- 与 URDF 对应的语义描述 (SRDF)，用于 MoveIt 规划 -->
  <param name="$(arg robot_description)_semantic" textfile="$(find aubo_e5_moveit_config)/config/aubo_e5.srdf" />

  <!-- 加载关节限位配置，覆盖 URDF 中的限位信息 -->
  <group ns="$(arg robot_description)_planning">
    <rosparam command="load" file="$(find aubo_e5_moveit_config)/config/joint_limits.yaml"/>
  </group>

  <!-- 加载运动学默认配置；可被节点命名空间内的设置覆盖 -->
  <group ns="$(arg robot_description)_kinematics">
    <rosparam command="load" file="$(find aubo_e5_moveit_config)/config/kinematics.yaml"/>
  </group>

</launch>
